{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "backend/**"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/_/backend/:path*",
      "destination": "/backend/api/index"
    }
  ]
}
